	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/sanitize-html": "^2.16.1",
		"@types/three": "^0.184.1",
		"@vitejs/plugin-react": "^4.3.4",
		"@webgpu/types": "^0.1.40",
		"autoprefixer": "^10.4.20",
		"electron": "^33.0.0",
		"electron-builder": "^25.0.0",
		"electron-vite": "^2.3.0",
		"happy-dom": "^20.9.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
